{
  "manifest_version": 3,
  "name": "Gemini Live Text-to-Speech",
  "version": "2.0.0",
  "description": "Transcribes selected text to audio using Google Gemini Multimodal Live API.",
  "browser_specific_settings": {
    "gecko": {
      "id": "tts-ext@jansenmtan"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "notifications",
    "offscreen",
    "scripting"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gemini TTS Controls",
	  "default_icon": {
		  "32": "icon-32.png"
	  }
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*, file:///*"],
      "js": ["content.js"]
    }
  ]
}
