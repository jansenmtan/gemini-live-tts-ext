{
  "manifest_version": 2,
  "name": "Gemini Live Text-to-Speech",
  "version": "0.1.0",
  "description": "Transcribes selected text to audio using Google Gemini Multimodal Live API.",
  "browser_specific_settings": {
    "gecko": {
      "id": "tts-ext@jansenmtan"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "notifications",
	"scripting",
    "<all_urls>"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Gemini TTS Controls",
	  "default_icon": {
		  "32": "icon-32.png"
	  }
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png"
  },
  "page_action": {
	  "default_icon": {
		  "16": "page_action-16.png",
		  "32": "page_action-32.png"
	  },
	"default_title": "Take screenshot to send to Gemini",
	"show_matches": ["<all_urls>"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
