{
  "manifest_version": 3,
  "name": "Gemini Live Text-to-Speech",
  "version": "2.4.0",
  "description": "Transcribes selected text to audio using Google Gemini Multimodal Live API.",
  "browser_specific_settings": {
    "gecko": {
      "id": "tts-ext@jansenmtan"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "notifications",
    "offscreen",
    "scripting"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "",
    "default_title": "Take screenshot to send to Gemini",
    "default_icon": {
      "32": "page_action-32.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*, file:///*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}